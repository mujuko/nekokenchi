{
  "name": "nekokenchi",
  "private": true,
  "license": "MIT",
  "version": "1.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:https": "node scripts/ensure-dev-cert.mjs && VITE_DEV_HTTPS=1 vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "deploy:tagged": "node scripts/deploy-if-tagged.mjs",
    "test": "vitest run",
    "preview": "vite preview",
    "preview:https": "node scripts/ensure-dev-cert.mjs && VITE_DEV_HTTPS=1 vite preview --host 0.0.0.0",
    "deploy:dev": "npx wrangler deploy --env dev",
    "deploy:prod": "node scripts/deploy-if-tagged.mjs --env production",
    "pre-release": "node scripts/pre-release.mjs"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.8"
  }
}
